{
  "name": "specforge",
  "version": "0.1.0",
  "private": true,
  "description": "Specification-driven engineering orchestration CLI",
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "bin": {
    "specforge": "dist/cli.js",
    "sf": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "ci:coverage": "tsx scripts/run-changed-lines-coverage-check.ts",
    "ci:policy": "tsx scripts/run-ci-policy-check.ts",
    "demo:golden": "tsx scripts/run-golden-demo.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "start": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
