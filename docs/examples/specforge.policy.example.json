{
  "coverage": {
    "scope": "changed-lines",
    "enforcement": "report-only"
  },
  "parallelism": {
    "max_concurrent_tasks": 2,
    "serialize_on_uncertainty": true
  },
  "gates": {
    "enabled_by_default": {
      "proposal_approval": true,
      "spec_approval": true,
      "execution_start": false,
      "merge_approval": true
    },
    "applicable_project_modes": {
      "proposal_approval": [
        "feature-proposal"
      ],
      "spec_approval": [
        "greenfield",
        "existing-repo",
        "contribution",
        "feature-proposal"
      ],
      "execution_start": [
        "greenfield",
        "existing-repo",
        "contribution",
        "feature-proposal"
      ],
      "merge_approval": [
        "greenfield",
        "existing-repo",
        "contribution",
        "feature-proposal"
      ]
    }
  }
}
